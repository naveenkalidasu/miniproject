<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - PropAI</title>
    <!-- Font Awesome for Google icon (free brand icon) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background: #f1f5f9;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        .container {
            background: white;
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.08);
            padding: 40px 36px;
            width: 100%;
            max-width: 400px;
        }
        .logo { text-align: center; margin-bottom: 4px; }
        .logo h1 { font-size: 26px; font-weight: 700; color: #1e293b; }
        .logo span { color: #3b82f6; }
        h2 { color: #1e293b; text-align: center; margin-bottom: 24px; font-weight: 600; font-size: 18px; }
        .form-group { margin-bottom: 18px; }
        label { display: block; margin-bottom: 6px; color: #475569; font-weight: 600; font-size: 13px; }
        .input-wrap { position: relative; }
        input {
            width: 100%;
            padding: 11px 14px;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            font-size: 14px;
            font-family: inherit;
        }
        input:focus { outline: none; border-color: #3b82f6; }
        .toggle-pw {
            position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
            background: none; border: none; cursor: pointer; font-size: 13px; color: #64748b;
        }
        .btn {
            width: 100%;
            padding: 12px;
            background: #3b82f6;
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        .btn:hover { background: #2563eb; }
        .btn:disabled { opacity: 0.6; cursor: not-allowed; }
        .spinner { display: none; width: 14px; height: 14px; border: 2px solid rgba(255,255,255,0.4); border-top-color: white; border-radius: 50%; animation: spin 0.6s linear infinite; }
        @keyframes spin { to { transform: rotate(360deg); } }
        .alert { padding: 12px 14px; border-radius: 10px; margin-bottom: 18px; font-size: 13px; }
        .alert-success { background: #dcfce7; color: #166534; border: 1px solid #86efac; }
        .alert-error { background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; }
        .register-link { text-align: center; margin-top: 18px; color: #64748b; font-size: 13px; }
        .register-link a { color: #3b82f6; text-decoration: none; font-weight: 600; }
        .register-link a:hover { text-decoration: underline; }
        .cloud-badge { text-align: center; font-size: 11px; color: #94a3b8; margin-top: 14px; }
        .cloud-badge span { background: #f0fdf4; padding: 4px 12px; border-radius: 999px; color: #16a34a; font-weight: 600; }

        /* --- Divider & Google button --- */
        .divider {
            display: flex;
            align-items: center;
            margin: 22px 0 18px;
            color: #94a3b8;
            font-size: 12px;
        }
        .divider::before, .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #e2e8f0;
        }
        .divider::before { margin-right: 14px; }
        .divider::after { margin-left: 14px; }

        .btn-google {
            width: 100%;
            padding: 12px;
            background: white;
            color: #1e293b;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            background-color: #fafafa;
            margin-top: 4px;
        }
        .btn-google:hover {
            background: #f1f5f9;
            border-color: #cbd5e1;
        }
        .btn-google i {
            font-size: 18px;
            color: #4285F4; /* classic Google blue */
        }
        .btn-google:active {
            background: #e9eef3;
        }
        /* small note: we keep the cloud badge at bottom */
    </style>
</head>
<body>
    <div class="container">
        <div class="logo"><h1>Prop<span>AI</span></h1></div>
        <h2>🔐 Welcome Back</h2>

        <!-- messages (placeholder, will be populated by server) -->
        <% if (messages.error_msg) { %>
            <div class="alert alert-error">⚠️ <%= messages.error_msg %></div>
        <% } %>
        <% if (messages.success_msg) { %>
            <div class="alert alert-success">✅ <%= messages.success_msg %></div>
        <% } %>

        <!-- standard login form -->
        <form action="/login" method="POST" id="loginForm">
            <div class="form-group">
                <label for="email">Email address</label>
                <input type="email" id="email" name="email" placeholder="you@example.com" required autocomplete="email">
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <div class="input-wrap">
                    <input type="password" id="password" name="password" placeholder="Enter your password" required autocomplete="current-password">
                    <button type="button" class="toggle-pw" id="togglePw">Show</button>
                </div>
            </div>
            <button type="submit" class="btn" id="submitBtn">
                <span class="spinner" id="spinner"></span>
                <span id="btnText">Sign in</span>
            </button>
        </form>

        <!-- Divider -->
        <div class="divider">or continue with</div>

        <!-- Sign in with Google button -->
        <button class="btn-google" id="googleSignInBtn">
            <i class="fab fa-google"></i> Sign in with Google
        </button>

        <div class="register-link">
            Don't have an account? <a href="/register">Create one now</a>
        </div>
        <div class="cloud-badge"><span>☁️ Cloud database · access from anywhere</span></div>
    </div>

    <script>
        (function() {
            // --- toggle password visibility ---
            const togglePw = document.getElementById('togglePw');
            const password = document.getElementById('password');
            if (togglePw && password) {
                togglePw.onclick = function() {
                    const isHidden = password.type === 'password';
                    password.type = isHidden ? 'text' : 'password';
                    togglePw.textContent = isHidden ? 'Hide' : 'Show';
                };
            }

            // --- login form submission feedback ---
            const form = document.getElementById('loginForm');
            const submitBtn = document.getElementById('submitBtn');
            const spinner = document.getElementById('spinner');
            const btnText = document.getElementById('btnText');

            if (form) {
                form.addEventListener('submit', function() {
                    submitBtn.disabled = true;
                    if (spinner) spinner.style.display = 'inline-block';
                    if (btnText) btnText.textContent = 'Signing in...';
                });
            }

            // --- Google Sign-In simulation (demo action) ---
            const googleBtn = document.getElementById('googleSignInBtn');
            if (googleBtn) {
                googleBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    // In a real implementation, this would redirect to Google OAuth or open a popup.
                    // For demonstration, we show a friendly alert that simulates the flow.
                    // We also add a tiny spinner-like feedback to the button (optional)
                    const originalText = googleBtn.innerHTML;
                    googleBtn.innerHTML = '<i class="fas fa-spinner fa-pulse" style="color:#4285F4;"></i> Connecting...';
                    googleBtn.disabled = true;

                    // Simulate async OAuth redirect (after 1.2s we restore and show a message)
                    setTimeout(function() {
                        // restore button
                        googleBtn.innerHTML = originalText;
                        googleBtn.disabled = false;
                        // Show a mock success message (or you could redirect to /auth/google)
                        // For this demo we mimic an OAuth redirect by showing an alert.
                        // In a real app you would window.location.href = '/auth/google';
                        // but we'll just show a message:
                        const msgDiv = document.createElement('div');
                        msgDiv.className = 'alert alert-success';
                        msgDiv.innerHTML = '✅ Google sign-in simulated. (Redirect to OAuth would happen here.)';
                        // insert after the button
                        const container = document.querySelector('.container');
                        const divider = document.querySelector('.divider');
                        // insert before divider
                        container.insertBefore(msgDiv, divider.nextSibling);
                        // remove after 5s
                        setTimeout(() => { if (msgDiv.parentNode) msgDiv.remove(); }, 5000);
                    }, 1200);
                });
            }

        })();
    </script>
</body>
</html>
