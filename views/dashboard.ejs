<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PropAI · next‑gen dashboard</title>
  <!-- Font Awesome 6 (free) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
  <!-- Google Font Inter -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet" />
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }

    body {
      background: #050816;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      /* animated grid + aurora effect (light) */
      position: relative;
      overflow-x: hidden;
    }

    /* floating gradient blobs / aurora background */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      z-index: 0;
      background: 
        radial-gradient(circle at 20% 30%, rgba(0, 229, 255, 0.06) 0%, transparent 50%),
        radial-gradient(circle at 80% 70%, rgba(124, 58, 237, 0.08) 0%, transparent 50%),
        radial-gradient(circle at 40% 80%, rgba(0, 255, 153, 0.04) 0%, transparent 40%);
      pointer-events: none;
    }

    /* glowing particles (mouse glow) */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      z-index: 0;
      background-image: radial-gradient(circle at 50% 50%, rgba(0,229,255,0.02) 0%, transparent 60%);
      pointer-events: none;
      animation: pulseGlow 8s infinite alternate;
    }

    @keyframes pulseGlow {
      0% { opacity: 0.3; }
      100% { opacity: 0.8; }
    }

    /* ––––– main dashboard – glassmorphism, dark AI theme ––––– */
    .dashboard {
      max-width: 1440px;
      width: 100%;
      background: rgba(17, 24, 39, 0.65);
      backdrop-filter: blur(16px) saturate(180%);
      -webkit-backdrop-filter: blur(16px) saturate(180%);
      border-radius: 48px;
      box-shadow: 0 40px 80px -20px rgba(0,0,0,0.8), 0 0 0 1px rgba(255,255,255,0.04);
      padding: 28px 32px 32px;
      border: 1px solid rgba(255,255,255,0.06);
      position: relative;
      z-index: 2;
      transition: all 0.2s;
    }

    /* ––– navbar ––– */
    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 16px 30px;
      padding-bottom: 18px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      margin-bottom: 28px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 700;
      font-size: 28px;
      letter-spacing: -0.02em;
      color: #ffffff;
    }

    .brand i {
      background: rgba(0, 229, 255, 0.12);
      padding: 10px 12px;
      border-radius: 18px;
      color: #00E5FF;
      font-size: 22px;
      box-shadow: 0 0 20px rgba(0, 229, 255, 0.15);
    }

    .brand span {
      background: linear-gradient(135deg, #00E5FF, #7C3AED);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .nav-actions {
      display: flex;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
    }

    .user-pill {
      display: flex;
      align-items: center;
      gap: 14px;
      background: rgba(255,255,255,0.04);
      padding: 5px 20px 5px 8px;
      border-radius: 60px;
      border: 1px solid rgba(255,255,255,0.06);
      backdrop-filter: blur(4px);
    }

    .avatar {
      width: 44px;
      height: 44px;
      border-radius: 40px;
      background: linear-gradient(145deg, #00E5FF, #7C3AED);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #050816;
      font-weight: 700;
      font-size: 20px;
      box-shadow: 0 0 24px rgba(0, 229, 255, 0.25);
    }

    .user-name {
      font-weight: 600;
      color: #f1f5f9;
      font-size: 16px;
    }

    .btn-logout {
      background: rgba(255,255,255,0.03);
      color: #cbd5e1;
      border: 1px solid rgba(255,255,255,0.06);
      padding: 10px 24px;
      border-radius: 60px;
      font-weight: 600;
      font-size: 14px;
      display: flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
      transition: 0.25s;
      text-decoration: none;
    }

    .btn-logout i { color: #94a3b8; }
    .btn-logout:hover {
      background: rgba(239, 68, 68, 0.08);
      border-color: #f87171;
      color: #fca5a5;
      box-shadow: 0 0 20px rgba(239,68,68,0.05);
    }
    .btn-logout:hover i { color: #f87171; }

    /* ––– alert ––– */
    .alert-success {
      background: rgba(0, 255, 153, 0.06);
      border: 1px solid rgba(0, 255, 153, 0.15);
      color: #a7f3d0;
      padding: 14px 24px;
      border-radius: 60px;
      margin-bottom: 28px;
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 15px;
      backdrop-filter: blur(4px);
    }

    /* ––– hero / AI command center ––– */
    .hero-card {
      background: linear-gradient(145deg, rgba(0, 229, 255, 0.06), rgba(124, 58, 237, 0.05));
      border-radius: 32px;
      padding: 32px 38px;
      margin-bottom: 32px;
      color: white;
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      box-shadow: 0 22px 40px -14px rgba(0,0,0,0.6), inset 0 0 0 1px rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.04);
      backdrop-filter: blur(4px);
      position: relative;
      overflow: hidden;
    }

    .hero-card::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 30% 20%, rgba(0,229,255,0.05), transparent 70%);
      pointer-events: none;
    }

    .hero-left {
      position: relative;
      z-index: 2;
    }
    .hero-left h1 {
      font-size: 30px;
      font-weight: 700;
      letter-spacing: -0.01em;
      display: flex;
      align-items: center;
      gap: 14px;
      flex-wrap: wrap;
    }

    .hero-left h1 i {
      background: rgba(0,229,255,0.08);
      padding: 8px 14px;
      border-radius: 40px;
      font-size: 22px;
      color: #00E5FF;
      box-shadow: 0 0 20px rgba(0,229,255,0.05);
    }

    .hero-left p {
      margin-top: 8px;
      opacity: 0.6;
      font-size: 17px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .cloud-badge {
      background: rgba(255,255,255,0.03);
      padding: 6px 20px;
      border-radius: 40px;
      font-size: 14px;
      font-weight: 500;
      color: #b8d0f0;
      border: 1px solid rgba(255,255,255,0.04);
      backdrop-filter: blur(4px);
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .hero-stats {
      display: flex;
      gap: 36px;
      background: rgba(0,0,0,0.2);
      padding: 10px 30px;
      border-radius: 80px;
      backdrop-filter: blur(8px);
      border: 1px solid rgba(255,255,255,0.04);
      position: relative;
      z-index: 2;
    }

    .stat-item { text-align: center; }
    .stat-number {
      font-size: 28px;
      font-weight: 700;
      color: #ffffff;
      text-shadow: 0 0 30px rgba(0,229,255,0.2);
    }
    .stat-label { font-size: 13px; opacity: 0.5; letter-spacing: 0.02em; color: #cbd5e1; }

    /* ––– grid: quick actions + profile ––– */
    .row-cards {
      display: grid;
      grid-template-columns: 1fr 1.7fr;
      gap: 24px;
      margin: 8px 0 24px;
    }

    @media (max-width: 840px) {
      .row-cards { grid-template-columns: 1fr; gap: 28px; }
    }

    .quick-actions {
      background: rgba(255,255,255,0.02);
      backdrop-filter: blur(8px);
      border-radius: 28px;
      padding: 24px 24px 28px;
      border: 1px solid rgba(255,255,255,0.04);
    }

    .quick-actions h3 {
      font-weight: 600;
      color: #f1f5f9;
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 16px;
      font-size: 18px;
    }

    .quick-grid {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .quick-card {
      background: rgba(255,255,255,0.02);
      padding: 18px 22px;
      border-radius: 20px;
      text-decoration: none;
      color: #f1f5f9;
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: 16px;
      transition: 0.25s;
      border: 1px solid rgba(255,255,255,0.04);
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
      position: relative;
      overflow: hidden;
    }

    .quick-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(0,229,255,0.02), transparent);
      opacity: 0;
      transition: 0.3s;
    }
    .quick-card:hover::before { opacity: 1; }

    .quick-card i {
      font-size: 24px;
      width: 44px;
      height: 44px;
      background: rgba(0,229,255,0.06);
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #00E5FF;
    }

    .quick-card .arrow {
      margin-left: auto;
      color: #64748b;
      font-size: 14px;
      transition: 0.2s;
    }

    .quick-card:hover {
      background: rgba(255,255,255,0.04);
      border-color: rgba(0,229,255,0.15);
      transform: translateY(-3px);
      box-shadow: 0 12px 30px -12px rgba(0,0,0,0.5), 0 0 20px rgba(0,229,255,0.02);
    }
    .quick-card:hover .arrow { color: #00E5FF; }

    /* profile card */
    .profile-card {
      background: rgba(255,255,255,0.02);
      backdrop-filter: blur(8px);
      border-radius: 28px;
      padding: 24px 24px 28px;
      border: 1px solid rgba(255,255,255,0.04);
    }

    .profile-card h3 {
      font-weight: 600;
      color: #f1f5f9;
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 16px;
      font-size: 18px;
    }

    .profile-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    .profile-item {
      background: rgba(0,0,0,0.15);
      padding: 16px 18px;
      border-radius: 18px;
      border: 1px solid rgba(255,255,255,0.03);
    }

    .profile-item .label {
      font-size: 12px;
      font-weight: 500;
      color: #94a3b8;
      letter-spacing: 0.02em;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .profile-item .value {
      font-size: 18px;
      font-weight: 600;
      color: #f8fafc;
      margin-top: 6px;
      word-break: break-word;
    }

    .badge-local {
      background: rgba(0,229,255,0.08);
      color: #00E5FF;
      padding: 2px 16px;
      border-radius: 60px;
      font-size: 13px;
      font-weight: 600;
      display: inline-block;
    }

    /* ––– cloud sync (glass) ––– */
    .sync-card {
      background: rgba(255,255,255,0.02);
      backdrop-filter: blur(8px);
      border-radius: 28px;
      padding: 24px 30px;
      margin-top: 20px;
      border: 1px solid rgba(255,255,255,0.04);
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      gap: 18px;
    }

    .sync-left {
      display: flex;
      align-items: center;
      gap: 18px;
    }

    .sync-left i {
      font-size: 28px;
      color: #00E5FF;
      background: rgba(0,229,255,0.04);
      padding: 14px;
      border-radius: 20px;
    }

    .sync-left div h4 {
      font-weight: 600;
      color: #f1f5f9;
      font-size: 18px;
    }
    .sync-left div p {
      color: #94a3b8;
      font-size: 14px;
    }

    .sync-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

    .sync-badge {
      background: rgba(255,255,255,0.02);
      padding: 8px 22px;
      border-radius: 40px;
      font-weight: 500;
      font-size: 13px;
      color: #cbd5e1;
      border: 1px solid rgba(255,255,255,0.04);
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .sync-badge i { color: #00E5FF; }

    /* ––– footer ––– */
    .footer-meta {
      margin-top: 28px;
      display: flex;
      justify-content: flex-end;
      opacity: 0.4;
      font-size: 13px;
      gap: 18px;
      color: #94a3b8;
      border-top: 1px solid rgba(255,255,255,0.04);
      padding-top: 20px;
    }

    @media (max-width: 600px) {
      .dashboard { padding: 18px 14px; border-radius: 32px; }
      .hero-card { flex-direction: column; align-items: flex-start; gap: 18px; }
      .hero-stats { width: 100%; justify-content: space-around; padding: 8px 8px; }
      .profile-grid { grid-template-columns: 1fr; }
      .sync-card { flex-direction: column; align-items: flex-start; }
      .brand { font-size: 24px; }
    }

    /* ––– animated stats (counter simulation via css) ––– */
    .stat-number {
      display: inline-block;
      animation: countUp 1.2s ease-out forwards;
    }

    @keyframes countUp {
      0% { opacity: 0.2; transform: translateY(6px); }
      100% { opacity: 1; transform: translateY(0); }
    }

    /* floating glass glow on cards */
    .quick-card, .profile-item, .sync-card, .hero-card {
      transition: box-shadow 0.3s;
    }
    .quick-card:hover {
      box-shadow: 0 0 30px rgba(0,229,255,0.03), 0 12px 30px -12px rgba(0,0,0,0.6);
    }
  </style>
</head>
<body>
<div class="dashboard">

  <!-- navbar -->
  <nav class="navbar">
    <div class="brand">
      <i class="fas fa-chart-simple"></i>
      Prop<span>AI</span>
    </div>
    <div class="nav-actions">
      <div class="user-pill">
        <div class="avatar">N</div>
        <span class="user-name">Naveen</span>
      </div>
      <a href="/logout" class="btn-logout">
        <i class="fas fa-sign-out-alt"></i> Logout
      </a>
    </div>
  </nav>

  <!-- flash message -->
  <div class="alert-success">
    <i class="fas fa-check-circle" style="color: #00E5FF;"></i>
    Resume score improved by 15% · AI insights updated
  </div>

  <!-- hero / AI command center -->
  <div class="hero-card">
    <div class="hero-left">
      <h1>
        <i class="fas fa-user-astronaut"></i> Welcome, Naveen
      </h1>
      <p>
        <i class="fas fa-cloud" style="opacity: 0.5;"></i>
        <span class="cloud-badge">
          <i class="fas fa-database"></i> MongoDB Atlas · live
        </span>
        <span style="margin-left: 8px; background: rgba(0,255,153,0.08); padding: 4px 16px; border-radius: 40px; font-size: 13px; border:1px solid rgba(0,255,153,0.1);">
          <i class="fas fa-robot"></i> AI Career Copilot
        </span>
      </p>
    </div>
    <div class="hero-stats">
      <div class="stat-item"><div class="stat-number" data-count="92">92%</div><div class="stat-label">Resume Score</div></div>
      <div class="stat-item"><div class="stat-number" data-count="14">14</div><div class="stat-label">Interviews</div></div>
      <div class="stat-item"><div class="stat-number" data-count="28">28</div><div class="stat-label">Skills Learned</div></div>
      <div class="stat-item"><div class="stat-number" data-count="156">156</div><div class="stat-label">Job Matches</div></div>
    </div>
  </div>

  <!-- row: quick actions + profile -->
  <div class="row-cards">
    <!-- AI Quick Actions -->
    <div class="quick-actions">
      <h3><i class="fas fa-bolt" style="color: #00E5FF;"></i> AI Launchpad</h3>
      <div class="quick-grid">
        <a href="/resume" class="quick-card">
          <i class="fas fa-file-alt"></i>
          <span>AI Resume Analyzer</span>
          <span class="arrow"><i class="fas fa-arrow-right"></i></span>
        </a>
        <a href="/interview" class="quick-card">
          <i class="fas fa-comment-dots"></i>
          <span>AI Interview (Voice+Cam)</span>
          <span class="arrow"><i class="fas fa-arrow-right"></i></span>
        </a>
        <a href="#" class="quick-card">
          <i class="fas fa-chart-line"></i>
          <span>AI Career Roadmap</span>
          <span class="arrow"><i class="fas fa-arrow-right"></i></span>
        </a>
      </div>
    </div>

    <!-- Profile card (modern) -->
    <div class="profile-card">
      <h3><i class="fas fa-id-card" style="color: #00E5FF;"></i> Profile</h3>
      <div class="profile-grid">
        <div class="profile-item">
          <div class="label"><i class="fas fa-user"></i> Full name</div>
          <div class="value">Naveen</div>
        </div>
        <div class="profile-item">
          <div class="label"><i class="fas fa-envelope"></i> Email</div>
          <div class="value">naveen@propai.io</div>
        </div>
        <div class="profile-item">
          <div class="label"><i class="fas fa-lock"></i> Auth</div>
          <div class="value"><span class="badge-local"><i class="fas fa-check-circle" style="margin-right: 6px;"></i>Local</span></div>
        </div>
        <div class="profile-item">
          <div class="label"><i class="fas fa-calendar"></i> Created</div>
          <div class="value">Jan 12, 2025</div>
        </div>
        <div class="profile-item" style="grid-column: 1 / -1;">
          <div class="label"><i class="fas fa-clock"></i> Last login</div>
          <div class="value">Today, 10:42 AM</div>
        </div>
      </div>
    </div>
  </div>

  <!-- cloud sync + AI insights (glass) -->
  <div class="sync-card">
    <div class="sync-left">
      <i class="fas fa-cloud-upload-alt"></i>
      <div>
        <h4>AI Insights · live</h4>
        <p><i class="fas fa-check-circle" style="color:#00E5FF; margin-right:6px;"></i> Resume improved by 15% · Python skill growing</p>
      </div>
    </div>
    <div class="sync-badges">
      <span class="sync-badge"><i class="fas fa-sync-alt fa-fw"></i> real-time</span>
      <span class="sync-badge"><i class="fas fa-lock fa-fw"></i> encrypted</span>
      <span class="sync-badge"><i class="fas fa-globe fa-fw"></i> any device</span>
      <span class="sync-badge"><i class="fas fa-database fa-fw"></i> auto backup</span>
    </div>
  </div>

  <!-- footer -->
  <div class="footer-meta">
    <span><i class="fas fa-shield-alt"></i> PropAI v3.0</span>
    <span>·</span>
    <span><i class="fas fa-cloud"></i> enterprise ready</span>
    <span>·</span>
    <span><i class="fas fa-robot"></i> AI copilot</span>
  </div>

</div>
</body>
</html>